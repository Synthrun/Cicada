# ─────────────────────────────────────────────────────────
#  Cicada — Security Audit Skill
#  Environment template (copy to .env and fill)
#  NEVER commit .env to version control
# ─────────────────────────────────────────────────────────

# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# ─── Database ──────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:changeme@localhost:5432/myapp
# Redis
REDIS_URL=redis://localhost:6379

# ─── Auth — JWT ────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_at_least_64_random_hex_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_to_another_random_string
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Auth — Session ────────────────────────────────────
SESSION_SECRET=change_me_to_a_random_string
SESSION_MAX_AGE=86400000

# ─── Auth — OAuth (optional) ──────────────────────────
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Password Reset ────────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=60
RESET_FROM_EMAIL=noreply@example.com
RESET_FROM_NAME=My App

# ─── Email — SMTP ──────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=My App

# ─── Email — Transactional API (optional) ─────────────
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# MAILGUN_API_KEY=xxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.example.com

# ─── Payments (optional) ──────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# ─── External APIs (optional) ─────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
# TELEGRAM_BOT_TOKEN=1234567890:AAH-xxxxxxxxxxxx

# ─── Firebase (optional) ──────────────────────────────
# FIREBASE_PROJECT_ID=my-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@my-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Cloudflare (optional) ────────────────────────────
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxx
# CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxx
# CLOUDFLARE_ZONE_ID=xxxxxxxxxxxx

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── File Upload ───────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Feature Flags ─────────────────────────────────────
ENABLE_SWAGGER=false
ENABLE_DEBUG_ROUTES=false
