# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
# Use postgresql://user:password@host:port/database format
DATABASE_URL=postgresql://user:changeme@localhost:5432/myapp

# ─── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Password Reset ───────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=60
# Sender email for password reset emails
RESET_FROM_EMAIL=noreply@example.com

# ─── OAuth (optional) ─────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Email ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Payments (optional) ──────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── External APIs (optional) ─────────────────────────
# OPENAI_API_KEY=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ─── Redis (optional) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Security ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=change_me_to_a_random_string
